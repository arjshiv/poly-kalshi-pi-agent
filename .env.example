# Kalshi execution. Keep private keys outside git.
KALSHI_ENV=demo
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
# Alternative to KALSHI_PRIVATE_KEY_PATH. Use literal \n between PEM lines.
KALSHI_PRIVATE_KEY_PEM=

# Safety gate. Leave false until dry-runs have been reviewed.
LIVE_TRADING_ENABLED=false

# Optional: override default data endpoints.
POLYMARKET_DATA_BASE_URL=https://data-api.polymarket.com
KALSHI_DEMO_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
KALSHI_PROD_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
